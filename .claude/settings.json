{
  "hooks": {
    "Stop": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "./gradlew test 2>&1 || true",
            "timeout": 60,
            "statusMessage": "Running unit tests..."
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "./qa/run.sh verify"
          }
        ]
      }
    ]
  }
}
