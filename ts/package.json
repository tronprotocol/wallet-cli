{
  "name": "wallet-cli",
  "version": "0.1.0",
  "description": "TRON + EVM standard CLI wallet (TypeScript)",
  "type": "module",
  "bin": {
    "wallet-cli": "./dist/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "depcruise": "depcruise src",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "license": "MIT",
  "dependencies": {
    "@ledgerhq/hw-app-trx": "^6.36.3",
    "@ledgerhq/hw-transport-node-hid": "^6.33.4",
    "@ledgerhq/hw-transport-node-speculos-http": "^6.36.4",
    "@noble/ciphers": "^2.2.0",
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@scure/base": "^2.2.0",
    "@scure/bip32": "^2.2.0",
    "@scure/bip39": "^2.2.0",
    "tronweb": "^6.3.0",
    "viem": "^2.52.2",
    "yaml": "^2.9.0",
    "yargs": "^18.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/yargs": "^17.0.35",
    "dependency-cruiser": "^17.4.3",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
